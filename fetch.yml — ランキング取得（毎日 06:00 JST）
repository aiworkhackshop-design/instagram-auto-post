name: Fetch Amazon Product

on:
  schedule:
    - cron: '0 */6 * * *'   # 6時間ごと
  workflow_dispatch:

jobs:
  fetch:
    runs-on: ubuntu-latest

    steps:
      - name: Get Product Data
        run: |
          curl https://instagram-auto-post.onrender.com/product > product.json

      - name: Show Result
        run: cat product.json
